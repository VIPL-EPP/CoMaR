<launch>

  <arg name="odomTopic" default="/state_estimator/pose_in_odom"/>
  <arg name="commandTopic" default="/local_guidance_path_follower/twist"/>
  <arg name="baseFrame" default="base"/>

  <arg name="trackingDis" default="0.25"/>
  <arg name="sensorOffsetX" default="0.4"/>
  <arg name="sensorOffsetY" default="0"/>
  <arg name="twoWayDrive" default="false"/>
  <arg name="maxSpeed" default="1.5"/>
  <arg name="cameraOffsetZ" default="0"/>
  <arg name="autonomyMode" default="true"/>
  <arg name="autonomySpeed" default="1.5"/>
  <arg name="joyToSpeedDelay" default="2.0"/>
  <arg name="baseInverted" default="false"/>

  <node pkg="path_following" exec="path_following_node" name="path_following" output="screen">
    <param name="sensorOffsetX" value="$(var sensorOffsetX)" />
    <param name="sensorOffsetY" value="$(var sensorOffsetY)" />
    <param name="pubSkipNum" type="integer" value="1" />
    <param name="twoWayDrive" value="$(var twoWayDrive)" />
    <param name="lookAheadDis" type="double" value="$(var trackingDis)" />
    <param name="yawRateGain" type="double" value="4.0" />
    <param name="stopYawRateGain" type="double" value="4.0" />
    <param name="maxYawRate" type="double" value="90.0" />
    <param name="maxSpeed" value="$(var maxSpeed)" />
    <param name="maxAccel" type="double" value="2.5" />
    <param name="switchTimeThre" type="double" value="1.0" />
    <param name="dirDiffThre" type="double" value="0.7" />
    <param name="stopDisThre" type="double" value="0.4" />
    <param name="slowDwnDisThre" type="double" value="0.3" />
    <param name="useInclRateToSlow" type="boolean" value="false" />
    <param name="inclRateThre" type="double" value="120.0" />
    <param name="slowRate1" type="double" value="0.25" />
    <param name="slowRate2" type="double" value="0.5" />
    <param name="slowTime1" type="double" value="2.0" />
    <param name="slowTime2" type="double" value="2.0" />
    <param name="useInclToStop" type="boolean" value="false" />
    <param name="inclThre" type="double" value="45.0" />
    <param name="stopTime" type="double" value="5.0" />
    <param name="noRotAtStop" type="boolean" value="false" />
    <param name="noRotAtGoal" type="boolean" value="true" />
    <param name="autonomyMode" value="$(var autonomyMode)" />
    <param name="autonomySpeed" value="$(var autonomySpeed)" />
    <param name="joyToSpeedDelay" value="$(var joyToSpeedDelay)" />
    <param name="odomTopic" type="string" value="$(var odomTopic)" />
    <param name="commandTopic" type="string" value="$(var commandTopic)" />
    <param name="baseFrame" value="$(var baseFrame)" />
    <param name="baseInverted" value="$(var baseInverted)" />
  </node>

</launch>
